{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.YUZU-Hub/wiring-diagram-mcp",
  "title": "VoltPlan Wiring Diagrams",
  "description": "Generate 12V/24V/48V wiring diagrams and size wires, fuses, batteries, solar, and inverters.",
  "repository": {
    "url": "https://github.com/YUZU-Hub/wiring-diagram-mcp",
    "source": "github"
  },
  "websiteUrl": "https://voltplan.app",
  "icons": [
    {
      "src": "https://mcp.voltplan.app/public/icon-96.png",
      "mimeType": "image/png",
      "sizes": ["96x96"]
    }
  ],
  "version": "0.2.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "wiring-diagram-mcp",
      "version": "0.2.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "URL of the VoltPlan API instance",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "VOLTPLAN_API_URL"
        }
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.voltplan.app/mcp"
    }
  ]
}
